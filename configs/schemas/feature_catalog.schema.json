{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FeatureCatalogConfig",
  "type": "object",
  "required": ["feature_families"],
  "properties": {
    "feature_families": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "enabled", "requires_target", "requires_external_data", "fold_safety", "leakage_risk"],
        "properties": {
          "name": { "type": "string" },
          "enabled": { "type": "boolean" },
          "requires_target": { "type": "boolean" },
          "requires_external_data": { "type": "boolean" },
          "fold_safety": { "type": "string", "enum": ["global_safe", "fold_safe", "high_risk"] },
          "leakage_risk": { "type": "string", "enum": ["low", "medium", "high"] },
          "transductive_risk": { "type": "string", "enum": ["low", "medium", "high"] },
          "intended_models": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

