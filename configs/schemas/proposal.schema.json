{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProposalConfig",
  "type": "object",
  "required": ["proposal", "feature"],
  "properties": {
    "proposal": {
      "type": "object",
      "required": ["proposal_id", "competition", "artifact_root"],
      "properties": {
        "proposal_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "competition": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "artifact_root": { "type": "string", "minLength": 1 },
        "owner": { "type": ["string", "null"], "minLength": 1 }
      },
      "additionalProperties": false
    },
    "feature": {
      "type": "object",
      "required": [
        "feature_id",
        "feature_family",
        "source_columns",
        "hypothesis",
        "validation_plan",
        "requires_target",
        "fold_safety",
        "leakage_risk",
        "transductive_risk"
      ],
      "properties": {
        "feature_id": { "type": "string", "minLength": 1 },
        "feature_family": { "type": "string", "minLength": 1 },
        "source_columns": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "hypothesis": { "type": "string", "minLength": 1 },
        "validation_plan": { "type": "string", "minLength": 1 },
        "requires_target": { "type": "boolean" },
        "fold_safety": {
          "type": "string",
          "enum": ["global_safe", "fold_safe", "high_risk"]
        },
        "leakage_risk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "transductive_risk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
