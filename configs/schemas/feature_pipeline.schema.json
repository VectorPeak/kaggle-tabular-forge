{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FeatureBuildConfig",
  "type": "object",
  "required": ["feature_build", "data", "transforms"],
  "properties": {
    "feature_build": {
      "type": "object",
      "required": ["feature_build_id", "competition", "artifact_root"],
      "properties": {
        "feature_build_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "competition": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "artifact_root": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "data": {
      "type": "object",
      "required": ["data_dir", "target", "id_column"],
      "properties": {
        "data_dir": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "id_column": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "transforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "columns", "mode"],
            "properties": {
              "type": { "const": "frequency" },
              "columns": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "mode": { "type": "string", "enum": ["count", "frequency"] },
              "fit_on": { "type": "string", "enum": ["train_only", "train_test"] }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type", "columns", "bins", "strategy"],
            "properties": {
              "type": { "const": "binning" },
              "columns": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "bins": { "type": "integer", "minimum": 1 },
              "strategy": { "type": "string", "enum": ["quantile"] }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type", "pairs"],
            "properties": {
              "type": { "const": "arithmetic_interactions" },
              "pairs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["left", "right", "operations"],
                  "properties": {
                    "left": { "type": "string", "minLength": 1 },
                    "right": { "type": "string", "minLength": 1 },
                    "operations": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "string",
                        "enum": ["add", "sub", "mul", "div"]
                      }
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
