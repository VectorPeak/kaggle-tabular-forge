{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StackingPreflightConfig",
  "type": "object",
  "required": ["stacking"],
  "properties": {
    "stacking": {
      "type": "object",
      "required": [
        "experiment_id",
        "competition",
        "artifact_root",
        "target",
        "id_column",
        "metric_name"
      ],
      "properties": {
        "experiment_id": { "type": "string", "minLength": 1 },
        "competition": { "type": "string", "minLength": 1 },
        "artifact_root": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "id_column": { "type": "string", "minLength": 1 },
        "metric_name": { "type": "string", "minLength": 1 },
        "candidate_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "top_n": { "type": ["integer", "null"], "minimum": 1 },
        "max_parents": { "type": ["integer", "null"], "minimum": 1 },
        "min_parents": { "type": ["integer", "null"], "minimum": 1 },
        "selection": {
          "type": "object",
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["score_desc", "diversity_greedy", "hill_climb_greedy"]
            },
            "max_pairwise_corr": {
              "type": ["number", "null"],
              "minimum": 0.0,
              "maximum": 1.0
            },
            "min_gain": {
              "type": ["number", "null"],
              "minimum": 0.0
            },
            "report_top_k_pairs": {
              "type": ["integer", "null"],
              "minimum": 1
            }
          },
          "additionalProperties": false
        },
        "stacker": {
          "type": "object",
          "required": ["method"],
          "properties": {
            "method": {
              "type": "string",
              "enum": ["preflight_only", "logistic_regression", "ridge_classifier"]
            },
            "params": { "type": "object" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
