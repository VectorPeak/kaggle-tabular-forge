{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExperimentConfig",
  "type": "object",
  "required": ["experiment", "data", "features", "model", "validation"],
  "properties": {
    "experiment": {
      "type": "object",
      "required": ["experiment_id", "competition"],
      "properties": {
        "experiment_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "competition": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "hypothesis": { "type": "string" },
        "base_experiment": { "type": ["string", "null"] },
        "seed": { "type": "integer" },
        "run_mode": { "type": "string", "enum": ["static_review", "smoke", "single_fold", "full_cv", "hpo"] },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "data": {
      "type": "object",
      "required": ["data_dir", "artifact_root", "target", "id_column"],
      "properties": {
        "data_dir": { "type": "string", "minLength": 1 },
        "artifact_root": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "id_column": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "features": { "type": "object" },
    "model": {
      "type": "object",
      "required": ["family"],
      "properties": {
        "family": { "type": "string" },
        "preset": { "type": "string" },
        "params": { "type": "object" }
      },
      "additionalProperties": true
    },
    "validation": { "type": "object" },
    "outputs": { "type": "object" }
  },
  "additionalProperties": true
}
